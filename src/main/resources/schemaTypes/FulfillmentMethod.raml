#%RAML 1.0 DataType

description: A single fulfillment method specifying how and where items are delivered
type: object
properties:
  type:
    type: string
    required: true
    description: Fulfillment method type
    enum: [shipping, pickup, digital]
    example: "shipping"
  line_item_ids:
    type: array
    required: true
    description: List of item IDs covered by this fulfillment method
    items:
      type: string
    example: ["WH1000XM5-BLK", "SONY-CASE-001"]
  destinations:
    type: array
    required: false
    description: One or more destination addresses for this fulfillment method
    items:
      type: !include Destination.raml
